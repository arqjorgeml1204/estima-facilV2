{
  "expo": {
    "name": "EstimaFácil",
    "slug": "estimafacil",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "estimafacil",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#003d9b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.estimafacil.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#003d9b"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.estimafacil.app",
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "31e1d3c5-fa0f-4e7c-96c4-27565587317e"
      }
    },
    "owner": "jorgeml"
  }
}
